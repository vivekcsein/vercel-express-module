APP_NAME="Enterprise Express Backend"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Production-ready Express backend"

NODE_ENV="development"

APP_HOST="localhost"
APP_PORT=7164

API_PATH="/api"

CLIENT_URL="http://localhost:3000"

APP_SECRET="super-secret-key"

JWT_ACCESS_SECRET="jwt-access-secret"
JWT_REFRESH_SECRET="jwt-refresh-secret"

ACCESS_TOKEN_EXPIRES_IN="1d"
REFRESH_TOKEN_EXPIRES_IN="30d"

COOKIE_SECRET="cookie-secret"
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE="lax"

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

DATABASE_URL=

REDIS_URL=
REDIS_TOKEN=

BETTER_AUTH_SECRET="better-auth-secret"
BETTER_AUTH_URL="http://localhost:7164"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

DEFAULT_USER_ID="default-user-id"
DEFAULT_USER_FULLNAME="John Doe"
DEFAULT_USER_EMAIL="johndoe@gmail.com"
DEFAULT_USER_PASSWORD="password#1234"

LOG_LEVEL="info"

ENABLE_SWAGGER=true
ENABLE_RATE_LIMIT=true
ENABLE_REQUEST_LOGGING=true