{
  "name": "vercel-express-module",
  "version": "1.0.0",
  "description": "A simple Express backend starter for Vercel with latest TypeScript and module support.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json && tsc-esm-fix --target='dist'",
    "clean": "rimraf dist",
    "start": "node dist/api/index.js",
    "start:local": "node dist/src/server.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "deprecation-check": "node --trace-deprecation ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.8.0",
    "@vercel/node": "^5.8.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "author": "@vivekcsein",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "keywords": [
    "vercel",
    "express",
    "typescript",
    "module",
    "node",
    "api"
  ]
}
