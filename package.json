{
  "name": "vercel-express-module",
  "version": "1.0.0",
  "description": "A simple Express backend starter for Vercel with latest TypeScript and module support.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json && tsc-esm-fix --target='dist'",
    "clean": "rimraf dist",
    "start": "node dist/api/index.js",
    "start:local": "node dist/src/server.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@vercel/node": "^5.8.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "keywords": [
    "vercel",
    "express",
    "typescript",
    "module",
    "node",
    "api"
  ]
}
